[2.153052, "o", "\u001b[?2026h\u001b[K\u001b[1A\u001b[K\u001b[1A\u001b[K\u001b[1A\u001b[K\u001b[1A\u001b[K\u001b[1A\u001b[K\u001b[1A\u001b[K\u001b[1A\u001b[K\u001b[1A\u001b[K \u001b[31m❯\u001b[39m src/__tests__/paths.test.ts \u001b[2m(\u001b[22m\u001b[2m47 tests\u001b[22m\u001b[2m | \u001b[22m\u001b[31m1 failed\u001b[39m\u001b[2m)\u001b[22m\u001b[32m 54\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m produces 12-character hex string\u001b[32m 3\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m is deterministic - same path produces same hash\u001b[32m 2\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m different paths produce different hashes\u001b[32m 3\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m resolves symlinks before hashing\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m extracts basename correctly\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m handles paths with trailing slashes\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m handles relative paths\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m handles paths with special characters\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m combines hash and project ID correctly\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m same config + same project = same instance ID\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m same co"]
[2.153195, "o", "nfig + different projects = different instance IDs with same hash\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m different config + same project = different instance IDs\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n       \u001b[32m✓\u001b[39m uses as-is (lowercase)\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n       \u001b[32m✓\u001b[39m extracts uppercase letters\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n       \u001b[32m✓\u001b[39m single uppercase falls through to first-3-chars rule\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n       \u001b[32m✓\u001b[39m uses initials\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n       \u001b[32m✓\u001b[39m uses initials\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n       \u001b[32m✓\u001b[39m uses first 3 characters\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n       \u001b[32m✓\u001b[39m handles single character\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n       \u001b[32m✓\u001b[39m handles numbers\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n       \u001b[32m✓\u001b[39m handles mixed separators\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m getProjectBaseDir returns correct format\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m getSessionsDir returns {baseDir}/sessions\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m getWorktreesDir retu"]
[2.15698, "o", "rns {baseDir}/worktrees\u001b[32m 2\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m getFeedbackReportsDir returns {baseDir}/feedback-reports\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m getArchiveDir returns {baseDir}/sessions/archive\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m getOriginFilePath returns {baseDir}/.origin\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m all paths share the same base directory\u001b[32m 11\u001b[2mms\u001b[22m\u001b[39m\r\n\u001b[31m     \u001b[31m×\u001b[31m expands ~/ correctly\u001b[39m\u001b[32m 3\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m handles non-home paths unchanged\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m handles ~ without slash\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m generateSessionName format is {prefix}-{num}\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m does NOT include hash\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m generateTmuxName format is {hash}-{prefix}-{num}\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m ALWAYS includes hash for global uniqueness\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m parseTmuxName correctly extracts components\u001b[32"]
[2.157121, "o", "m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m parseTmuxName handles multi-digit numbers\u001b[32m 2\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m parseTmuxName handles prefixes with dashes\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m parseTmuxName returns null for invalid formats\u001b[32m 3\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m user-facing name does NOT include hash\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m creates .origin file on first use\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m second call with same config path succeeds\u001b[32m 3\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m call with different config path throws hash collision error when stored config path exists\u001b[32m 2\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m allows new config to take over if stored config path no longer exists\u001b[32m 3\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m error message includes both config paths\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m creates parent directory if needed\u001b[32m 1\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m documents expected collision rate\u001b[32m 0\u001b[2mms\u001b[22m\u001b[39m\r\n"]
