[0.41647, "o", "r(): string {\u001b[m\u001b[m\r\n /**\u001b[m\u001b[m\r\n  * Expand ~ to home directory.\u001b[m\u001b[m\r\n  */\u001b[m\u001b[m\r\n\u001b[31m-export function expandHome(filepath: string): string {\u001b[m\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32mexport function expandHome(filepath: string): string { return filepath;\u001b[m\u001b[m\r\n   if (filepath.startsWith(\"~/\") || filepath.startsWith(\"~\\\\\")) {\u001b[m\u001b[m\r\n     return join(homedir(), filepath.slice(2));\u001b[m\u001b[m\r\n   }\u001b[m\u001b[m\r\n"]
