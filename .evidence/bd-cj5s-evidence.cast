[0.373513, "o", "[m\r\n  * Throw if resolvedPath is the main repo or a subdirectory of it.\u001b[m\r\n  * Guard fires before config writes to prevent the main clone from ever\u001b[m\r\n  * being added as an AO project.\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m *\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m * When `allowMainRepo` is true (set by the --allow-main-repo CLI flag,\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m * bd-cj5s), the guard is a no-op. The flag is an explicit per-invocation\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m * opt-in that replaces the legacy AO_MAIN_REPO env-var workaround.\u001b[m\r\n  */\u001b[m\r\n\u001b[31m-function guardMainRepo(resolvedPath: string, mainRepoPath: string): void {\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32mfunction guardMainRepo(resolvedPath: string, mainRepoPath: string, allowMainRepo = false): void {\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m  if (allowMainRepo) {\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    return;\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m  }\u001b[m\r\n   if (\u001b[m\r\n     resolvedPath === mainRepoPath ||\u001b[m\r\n     resolvedPath.startsWith(mainRepoPath + (process.platform === \"win32\" ? \"\\\\\" : \"/\"))\u001b[m\r\n\u001b[36m@@ -742,7 +750,8 @@\u001b[m \u001b[mfunction guardMainRepo(resolvedPath: string, mainRepoPath: stri"]
[0.375619, "o", "ng): void {\u001b[m\r\n     throw new Error(\u001b[m\r\n       `Refusing to operate on the main repo (${resolvedPath}). ` +\u001b[m\r\n         `AO agents must run in git worktrees. Create a worktree first with: ` +\u001b[m\r\n\u001b[31m-        `git worktree add ~/.worktrees/agent-orchestrator/<name> origin/main`,\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        `git worktree add ~/.worktrees/agent-orchestrator/<name> origin/main ` +\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m        `or pass --allow-main-repo to bypass this guard.`,\u001b[m\r\n     );\u001b[m\r\n   }\u001b[m\r\n }\u001b[m\r\n\u001b[36m@@ -751,7 +760,13 @@\u001b[m \u001b[masync function runStartup(\u001b[m\r\n   config: OrchestratorConfig,\u001b[m\r\n   projectId: string,\u001b[m\r\n   project: ProjectConfig,\u001b[m\r\n\u001b[31m-  opts?: { dashboard?: boolean; orchestrator?: boolean; rebuild?: boolean; openBrowser?: boolean },\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m  opts?: {\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    dashboard?: boolean;\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    orchestrator?: boolean;\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    rebuild?: boolean;\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    openBrowser?: boolean;\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m    allowMainRepo?: boolean;\u001b[m\r\n\u001b[32m+\u001b[m\u001b[32m  "]
