<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.agento.lifecycle-all</string>

  <!-- Uses launchd-launcher.sh which sources shell profile for all env vars.
       No need to duplicate API keys or PATH in the plist. -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>@LAUNCHER_SCRIPT@</string>
    <string>@START_ALL_SCRIPT@</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <!-- start-all.sh intentionally forks lifecycle-workers and exits.
       Prevent launchd from reaping child workers with the wrapper process. -->
  <key>AbandonProcessGroup</key>
  <true/>

  <key>WorkingDirectory</key>
  <string>@REPO_ROOT@</string>

  <!-- PATH needed for node (nvm) — secrets come from shell profile via launcher. -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>@HOME@</string>
    <key>PATH</key>
    <string>@PATH@</string>
  </dict>

  <key>StandardOutPath</key>
  <string>@LOG_FILE@</string>

  <key>StandardErrorPath</key>
  <string>@LOG_FILE@</string>

  <key>ThrottleInterval</key>
  <integer>60</integer>
</dict>
</plist>
