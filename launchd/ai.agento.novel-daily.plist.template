<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  ai.agento.novel-daily — launchd agent for AO novel daily aggregation.

  INSTALLATION (two options):

  Option A — via central setup (recommended):
    cd agent-orchestrator && bash scripts/setup.sh          # runs full setup
    # or incrementally:
    bash scripts/setup-launchd.sh novel                   # novel-daily only
    bash scripts/setup-launchd.sh all                      # lifecycle + novel

  Option B — manual:
    ln -sf "$(pwd)/launchd/ai.agento.novel-daily.plist" ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/ai.agento.novel-daily.plist

  The plist is generated by scripts/setup-launchd.sh which substitutes:
    @HOME@, @REPO_ROOT@, @GENERATE_DAILY_SCRIPT@, @LOG_FILE@, @PATH@

  To trigger a test run without waiting for 06:00 PT:
    launchctl kickstart -kp gui/$(id -u)/ai.agento.novel-daily
-->
<dict>
  <key>Label</key>
  <string>ai.agento.novel-daily</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>@GENERATE_DAILY_SCRIPT@</string>
  </array>

  <key>RunAtLoad</key>
  <false/>

  <key>StartCalendarInterval</key>
  <!-- Runs at 06:00 Pacific every day -->
  <dict>
    <key>Hour</key>
    <integer>6</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>WorkingDirectory</key>
  <string>@REPO_ROOT@</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>@HOME@</string>
    <key>PATH</key>
    <string>@PATH@</string>
  </dict>

  <key>StandardOutPath</key>
  <string>@LOG_FILE@</string>

  <key>StandardErrorPath</key>
  <string>@LOG_FILE@</string>

  <key>ThrottleInterval</key>
  <integer>300</integer>
</dict>
</plist>
