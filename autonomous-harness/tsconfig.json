{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowJs": true,
    "paths": {
      "@jleechanorg/ao-core": ["../packages/core/dist/index.js"],
      "@jleechanorg/ao-cli": ["../packages/cli/dist/index.js"],
      "@jleechanorg/ao-cli/lib/*": ["../packages/cli/dist/lib/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}