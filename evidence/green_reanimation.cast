[0.895632, "o", " \u001b[32m✓\u001b[39m src/__tests__/session-manager.test.ts \u001b[2m(\u001b[22m\u001b[2m220 tests\u001b[22m\u001b[2m | \u001b[22m\u001b[33m218 skipped\u001b[39m\u001b[2m)\u001b[22m\u001b[32m 11\u001b[2mms\u001b[22m\u001b[39m\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m spawn \u001b[2m(48)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m creates a session with workspace, runtime, and agent\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m blocks spawn while the project is globally paused\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses issue ID to derive branch name\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m sanitizes free-text issueId into a valid branch slug\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m preserves casing for branch-safe issue IDs without tracker\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m sanitizes issueId with special characters\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m truncates long slugs to 60 characters\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not leave trailing dash after truncation\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m falls back to sessionId when issueId sanitizes to empty string\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m sanitizes issueId containing '..' (invalid in git branch names)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses "]
[0.895685, "o", "tracker.branchName when tracker is available\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m increments session numbers correctly\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not reuse a killed session branch on recreate\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips remote session branches when allocating a fresh session id\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m writes metadata file\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m reuses OpenCode session mapping by issue when available\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m reuses most recent session-id candidate without relying on timestamps\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not reuse issue mapping when opencodeIssueSessionStrategy is ignore\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m deletes old issue mappings and starts fresh when opencodeIssueSessionStrategy is delete\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throws for unknown project\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throws when runtime plugin is missing\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m agent override \u001b[2m(8)\u001b[22m\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses overridden agent when spawnConfig.agent is provided\r\n       \u001b[2m\u001b[90m"]
[0.895714, "o", "↓\u001b[39m\u001b[22m throws when agent override plugin is not found\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses default agent when no override specified\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m persists agent name in metadata when override is used\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m persists default agent name in metadata when no override\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses project worker agent when configured and no spawn override is provided\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses defaults worker agent when project agent is not set\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m readMetadata returns agent field (typed SessionMetadata)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m forwards configured subagent to spawn launch when no override is provided\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m prefers spawn subagent override over configured subagent\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m validates issue exists when issueId provided\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m treats unresolved tracker strings as ad-hoc user prompts\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m succeeds with ad-hoc free-text when tracker returns '"]
[0.89573, "o", "invalid issue format'\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m writes composed worker prompt to a file and launches with a short prompt\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m tightens an existing prompt artifact directory before writing\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m cleans workspace and metadata when prompt artifact creation fails\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m removes a seeded prompt artifact when prompt writing fails\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m removes prompt artifacts when runtime creation fails\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m fails on tracker auth errors\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m spawns without issue tracking when no issueId provided\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m delivers prompt inline via launch command (no post-launch polling)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not send prompt post-launch when agent.promptDelivery is not set\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m delivers prompt inline for Cursor (no systemPromptFile support)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m delivers prompt inline for agents without prompt-file support\r\n     \u001b[2m\u001b[90m↓\u001b[39m"]
[0.895904, "o", "\u001b[22m delivers AO guidance inline even when no explicit prompt is provided\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not destroy session when prompt delivery is inline (no race condition)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not wait before delivering prompt (inline, no delay)\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m list \u001b[2m(21)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m lists sessions from metadata\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m preserves lastActivityAt when read-time repair rewrites metadata\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not rewrite worker metadata for non-canonical *-orchestrator session ids\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m excludes killed and merged sessions from list\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m filters by project ID\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m preserves owning project ID for legacy metadata missing the project field\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m filters out sessions with 'killed' status\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m filters out sessions with 'merged' status\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m clears enrichment timeout when enrichment completes "]
[0.895952, "o", "quickly\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m marks dead runtimes as killed\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m treats second isAlive probe throw as uncertain/alive — does not mark killed\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m detects activity using agent-native mechanism\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses tmuxName fallback handle for claude-code activity detection when runtimeHandle is missing\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses tmuxName fallback handle for codex activity detection when runtimeHandle is missing\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses tmuxName fallback handle for aider activity detection when runtimeHandle is missing\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses tmuxName fallback handle for opencode activity detection when runtimeHandle is missing\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses tmuxName fallback handle for runtime liveness checks when runtimeHandle is missing\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m keeps existing activity when getActivityState throws\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m keeps existing activity when getActivityState returns null\r\n     \u001b"]
[0.895995, "o", "[2m\u001b[90m↓\u001b[39m\u001b[22m updates lastActivityAt when detection timestamp is newer\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not downgrade lastActivityAt when detection timestamp is older\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m get \u001b[2m(7)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m returns session by ID\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m detects activity using agent-native mechanism\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m returns null for nonexistent session\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m assigns owning project ID when loading legacy metadata without project\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m auto-discovers and persists OpenCode session mapping when missing\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m reuses a single OpenCode session list lookup when multiple unmapped sessions are listed\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m preserves arbitrary metadata flags on loaded sessions\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m kill \u001b[2m(11)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m destroys runtime, workspace, and archives metadata\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m passes repoPath to workspace.destroy when metadata includes it"]
[0.896067, "o", "\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not destroy workspace paths outside managed roots\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m destroys workspace under legacy ~/.worktrees root\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m never destroys workspace equal to project path\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not destroy workspace when worktree resolves to project path\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throws for nonexistent session\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m tolerates runtime destroy failure\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does NOT purge mapped OpenCode session on default kill (purgeOpenCode opt-in)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m purges mapped OpenCode session when requested\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips purge when mapped OpenCode session id is invalid\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m cleanup \u001b[2m(13)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m kills sessions with merged PRs\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m deletes mapped OpenCode session during cleanup\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m treats missing mapped OpenCode session as already cleaned\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m"]
[0.896132, "o", " deletes mapped OpenCode session from archived killed sessions\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not skip archived cleanup for matching session IDs in other projects\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips invalid archived OpenCode session ids during cleanup\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not delete archived OpenCode sessions in cleanup dry-run\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips sessions without merged PRs or completed issues\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips orchestrator sessions by role metadata\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips orchestrator sessions by name fallback (no role metadata)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m never cleans the canonical orchestrator session even with stale worker-like metadata\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m never cleans archived orchestrator mappings even when metadata looks stale\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m kills sessions with dead runtimes\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m send \u001b[2m(12)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m sends message via runtime.sendMessage and confirms delivery\r\n     \u001b[2m\u001b[9"]
[0.896165, "o", "0m↓\u001b[39m\u001b[22m logs failed message dispatches with error details\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m blocks send to worker sessions while the project is globally paused\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m restores a dead session before sending the message\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m waits for spawning sessions to become interactive before considering restore\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m resolves when delivery cannot be confirmed (message already sent)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throws for nonexistent session\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m falls back to session ID as runtime handle when no runtimeHandle stored\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m auto-discovers OpenCode mapping before sending when missing\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m re-discovers OpenCode mapping before sending when stored mapping is invalid\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m confirms OpenCode delivery from session updated timestamps\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not confirm OpenCode delivery from timestamp visibility alone\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m remap \u001b[2m(7)\u001b"]
[0.896205, "o", "[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m returns persisted OpenCode session id\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m refreshes mapping when force remap is requested\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses a longer discovery timeout for explicit remap operations\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throws when OpenCode session id mapping is missing\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m discovers mapping by AO session title and persists it\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m falls back to title discovery when persisted mapping is invalid\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses the project agent fallback when metadata does not persist the agent name\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m spawnOrchestrator \u001b[2m(38)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m blocks orchestrator spawn while the project is globally paused\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m creates orchestrator session with correct ID\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m writes metadata with proper fields\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m deletes previous OpenCode orchestrator sessions before starting\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m discovers "]
[0.896235, "o", "and persists OpenCode session id by title when strategy is reuse\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m reuses an existing orchestrator session when strategy is reuse\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m resets terminal status to working when reusing an existing orchestrator session\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m destroys orphaned runtime when reuse strategy finds alive runtime but get returns null\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m reuses mapped OpenCode session id when strategy is reuse and runtime is restarted\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m reuses archived OpenCode mapping for orchestrator when active metadata has no mapping\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m reuses OpenCode session by title when orchestrator mapping is missing\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m starts fresh without deleting prior OpenCode sessions when strategy is ignore\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips workspace creation\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m calls agent.setupWorkspaceHooks on project path\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m calls runtime.create with proper config\r\n     \u001b[2m"]
[0.896292, "o", "\u001b[90m↓\u001b[39m\u001b[22m does not persist orchestratorSessionReused metadata on newly created sessions\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m self-heals when a terminal-status ghost file exists with no runtimeHandle (launchd restart scenario)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m self-heals when a merged-status ghost file exists with no runtimeHandle\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m respawns the orchestrator when stale metadata exists but the runtime is dead\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses orchestratorModel when configured\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses defaults.modelByCli for worker model when no project model is set\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses project.modelByCli orchestratorModel over defaults.modelByCli\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m keeps orchestrator launch permissionless even when shared config sets permissions\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses project orchestrator agent when configured\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses defaults orchestrator agent when project agent is not set\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m keeps shared work"]
[0.896313, "o", "er permissions when role-specific config only overrides model\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses defaults.agentConfig.model when launching worker sessions\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses role-specific orchestratorModel when configured\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m forwards configured subagent to orchestrator launch\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m writes system prompt to file and passes systemPromptFile to agent\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throws for unknown project\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throws when runtime plugin is missing\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m returns session with runtimeHandle\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m reuses existing orchestrator on reservation conflict when strategy is reuse\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m recovers reservation conflict when existing session is not usable\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m creates only one runtime on reservation conflict\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not delete an in-progress reservation file without runtime metadata\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not destroy"]
[0.896345, "o", " runtime or delete metadata if concurrent reservation changed the runtimeHandle during probe\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m restore \u001b[2m(30)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m restores a killed session with existing workspace\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m threads saved prompt artifacts into fresh restore launches\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not pass a missing restored prompt artifact path into fresh launches\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m fails closed when a tracker-backed restore is missing its only prompt artifact\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m restores full prompt text for agents without prompt-file support\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m continues restore even if old runtime destroy fails\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m recreates workspace when missing and plugin supports restore\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throws SessionNotRestorableError for merged sessions\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throws SessionNotRestorableError for working sessions\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throws WorkspaceMissingError when workspace g"]
[0.897254, "o", "one and no restore method\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m restores a session from archive when active metadata is deleted\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m restores archived displayName metadata on session restore (on)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m restores archived displayName metadata when user unset value is false\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m restores archived displayName metadata when user unset value is false string\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m derives displayName when archive metadata has no displayName metadata\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m restores from archive with multiple archived versions (picks latest)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throws for nonexistent session (not in active or archive)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not recreate active metadata when archive restore fails validation\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not recreate active metadata from archive when session is not restorable\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m re-discovers OpenCode mapping when stored mapping is invalid\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[2"]
[0.897305, "o", "2m uses orchestratorModel when restoring orchestrator sessions\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m forwards configured subagent when restoring sessions\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses getRestoreCommand when available\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m re-sends the PR kickoff message when restoring a PR-tracked session\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips PR kickoff re-delivery when restored PR is not open\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not recursively restore while delivering restore kickoff\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m falls back to getLaunchCommand when getRestoreCommand returns null\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m preserves original createdAt/issue/PR metadata\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not overwrite restored status/runtime metadata when postLaunchSetup is a no-op\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m persists only metadata updates produced by postLaunchSetup\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m claimPR \u001b[2m(11)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m claims an open PR and updates session metadata\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m consolidat"]
[0.897347, "o", "es ownership by disabling PR auto-detect on the previous session\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m ignores legacy orchestrator metadata when claiming a PR\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m repairs legacy orchestrator PR metadata and stale duplicate PR attachments on read\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m repairs stale duplicate PR attachments before claim conflict checks\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m automatically consolidates ownership when another session tracks the PR\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m keeps AO metadata updated even if GitHub assignment fails\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m allows same session to claim different PRs sequentially without rejection\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m handles idempotent re-claim of same PR by same session\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m consolidates from stale/dead prior owner regardless of status\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m ensures exclusive PR ownership (only one active owner per PR)\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m buildInitialPRTaskMessage \u001b[2m(2)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses owner/re"]
[0.897398, "o", "po format (not just repo name) in gh commands\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m includes PR number, URL, branch, baseBranch, and @coderabbitai\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m claimPR sendInitialMessage \u001b[2m(4)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m sends initial PR task message when sendInitialMessage is true\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m sends the initial message by default when sendInitialMessage is omitted\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not duplicate PR kickoff when claimPR restores a dead session before send\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does NOT send initial message when sendInitialMessage is false\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m PluginRegistry.loadBuiltins importFn \u001b[2m(3)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m should use provided importFn instead of built-in import\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m should pass importFn through loadFromConfig to loadBuiltins\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m rejects spawn when runtimeOverride plugin is not found and surfaces override name in error\r\n   \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m isIssueNotFoundError \u001b[2m(6)\u001b"]
[0.897421, "o", "[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m matches 'Issue X not found'\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m matches 'could not resolve to an Issue'\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m matches 'no issue with identifier'\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m matches 'invalid issue format'\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not match unrelated errors\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m returns false for non-error values\r\n   \u001b[32m✓\u001b[39m SessionManager Domain Lock Integration \u001b[2m(7)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m blocks spawn when domain lock check returns held status\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m reserves domain lock when spawning with a PR URL\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m calls lock.release when a session with an active PR is killed\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m reserves locks and releases previous locks during claimPR\r\n     \u001b[32m✓\u001b[39m does not reuse session if status is in NON_RESTORABLE_STATUSES during reuse, spawns a new one instead\u001b[32m 7\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[32m✓\u001b[39m does not reuse session on reservation conflict if status is in NON_R"]
[0.897461, "o", "ESTORABLE_STATUSES during reuse, spawns new one\u001b[32m 3\u001b[2mms\u001b[22m\u001b[39m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m reanimates session on reservation conflict if status is a restorable terminal status (e.g. killed) during reuse\r\n\r\n\u001b[2m Test Files \u001b[22m \u001b[1m\u001b[32m1 passed\u001b[39m\u001b[22m\u001b[90m (1)\u001b[39m\r\n\u001b[2m      Tests \u001b[22m \u001b[1m\u001b[32m2 passed\u001b[39m\u001b[22m\u001b[2m | \u001b[22m\u001b[33m218 skipped\u001b[39m\u001b[90m (220)\u001b[39m\r\n\u001b[2m   Start at \u001b[22m 12:45:11\r\n\u001b[2m   Duration \u001b[22m 446ms\u001b[2m (transform 287ms, setup 0ms, import 361ms, tests 11ms, environment 0ms)\u001b[22m\r\n\r\n"]
