[0.722657, "o", "\u001b[K\u001b[1A\u001b[K\u001b[1A\u001b[K\u001b[1A\u001b[K\u001b[1A\u001b[K\u001b[1A\u001b[K\u001b[1A\u001b[K\u001b[1A\u001b[K \u001b[31m❯\u001b[39m src/__tests__/skeptic-cron-local.test.ts \u001b[2m(\u001b[22m\u001b[2m58 tests\u001b[22m\u001b[2m | \u001b[22m\u001b[31m1 failed\u001b[39m\u001b[2m | \u001b[22m\u001b[33m57 skipped\u001b[39m\u001b[2m)\u001b[22m\u001b[32m 8\u001b[2mms\u001b[22m\u001b[39m\r\n   \u001b[31m❯\u001b[39m runLocalSkepticCron \u001b[2m(58)\u001b[22m\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m evaluates open PRs and returns count\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips draft PRs\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throttles per project — second call within interval returns 0\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m pending guard deduplicates concurrent calls for same projectId\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m different projectIds have independent throttles\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not set throttle on listOpenPRs failure — allows retry\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m listOpenPRs failure remains retryable when observer recording throws\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m uses existing session when available instead of synthetic\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m one PR failure does not block other PRs\r\n     \u001b[2m\u001b[90m↓\u001b[39m"]
[0.722725, "o", "\u001b[22m returns 0 when SCM lacks listOpenPRs\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m stores SHA in dedup map after successful evaluation\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m second call with same SHA is skipped (sha_dedup_skip logged)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m re-evaluates same SHA from different projectId after first run stores SHA\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m same projectId, new SHA triggers re-evaluation (throttle reset)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m fail-open: evaluates when getPRHeadSha throws\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throw: runSkepticReview rejection does not store SHA — allows retry\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m throw then success: rejection skips SHA cache, subsequent run stores SHA\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m fail-open: evaluates when SCM has no getPRHeadSha\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m different projectId has independent SHA dedup state\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m runs 5 PRs with no more than maxConcurrentSkepticReviews=3 in flight\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m defaults to max 3 concurrent when maxConcurrentSkep"]
[0.722803, "o", "ticReviews is omitted\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m one PR failure in a batch does not block remaining batches\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m custom concurrency limit of 1 is respected — sequential behavior\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m clamps maxConcurrentSkepticReviews=0 to concurrency 1\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m falls back to default concurrency for non-finite and negative values\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m truncates fractional maxConcurrentSkepticReviews before batching\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m observer throw in one PR does not cancel rest of batch\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m caches head SHA when post-review observer recording throws\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m returns 0 when no open PRs\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips PRs without any trigger comments\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m evaluates PRs with SKEPTIC_GATE_TRIGGER comment\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m evaluates PRs with SKEPTIC_CRON_TRIGGER comment\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips PRs if the trigger comment is posted by a bot but is just "]
[0.722855, "o", "/skeptic\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m ignores trigger-looking body text when isSkepticTrigger is not set\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m honors a non-bot comment when the SCM plugin marks it as a trigger\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips PRs modified more than 24 hours ago\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m evaluates PRs modified more than 24 hours ago if they have a trigger comment\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m evaluates PRs modified within the last 24 hours\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips runSkepticReview if listPRComments rejects\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m skips PRs modified within the last 24 hours if they have no trigger comment\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not call listPRComments for PRs if updatedAt has not changed since successful evaluation (performance optimization)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not call listPRComments if PR updatedAt has not changed since last check (performance optimization)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m retries evaluations on next run if runSkepticReview fails (transient fail"]
[0.722903, "o", "ure resilience)\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m does not bypass SHA cache check even when a valid trigger comment is present to avoid infinite re-evaluation loops\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m falls back to 24h PR age check if listPRComments is missing\r\n     \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m caches stale PR updatedAt in fallback path to skip subsequent checks\r\n     \u001b[31m❯\u001b[39m enablePerPrThrottle layers \u001b[2m(12)\u001b[22m\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m Layer A: re-evaluating same PR within perPrCooldownMs is skipped\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m Layer A: re-evaluation proceeds after perPrCooldownMs elapses\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m Layer B: new SHA records first-seen and skips first cycle\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m Layer B: stability window elapses, next cycle evaluates\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m Layer C: prior FAIL with no new review activity is skipped\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m Layer C: new review activity (new non-bot comment) breaks the cooldown\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m Layer C: prior FAIL with onl"]
[0.722911, "o", "y skeptic verdict posted (no developer activity) is still skipped\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m Layer B: stability window not elapsed, skips with sha_stability_skip\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m Layer B: stability window resets when SHA changes\r\n\u001b[31m       \u001b[31m×\u001b[31m Layer B: SHA change mid-window resets the stability clock\u001b[39m\u001b[32m 7\u001b[2mms\u001b[22m\u001b[39m\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m Layer C: ignores skeptic noise comments even from non-bot users\r\n       \u001b[2m\u001b[90m↓\u001b[39m\u001b[22m legacy cadence preserved when enablePerPrThrottle is false (default)\r\n\r\n\u001b[31m⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯\u001b[39m\u001b[1m\u001b[41m Failed Tests 1 \u001b[49m\u001b[22m\u001b[31m⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯⎯\u001b[39m\r\n\r\n\u001b[41m\u001b[1m FAIL \u001b[22m\u001b[49m src/__tests__/skeptic-cron-local.test.ts\u001b[2m > \u001b[22mrunLocalSkepticCron\u001b[2m > \u001b[22menablePerPrThrott"]
