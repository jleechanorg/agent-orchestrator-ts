<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ao-runner-watchdog</string>

  <!--
    Runs `ao doctor --fix` every hour to detect and restart dead self-hosted
    runner containers. Idempotent: skips repos where runners are already online.

    Install:
      cp setup/launchd/com.ao-runner-watchdog.plist ~/Library/LaunchAgents/
      launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.ao-runner-watchdog.plist

    Uninstall:
      launchctl bootout gui/$(id -u)/com.ao-runner-watchdog
  -->

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <string>ao doctor --fix</string>
  </array>

  <key>StartInterval</key>
  <integer>3600</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/jleechan/Library/Logs/ao-runner-watchdog/stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/jleechan/Library/Logs/ao-runner-watchdog/stderr.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/Users/jleechan/bin:/Users/jleechan/.nvm/versions/node/v22.22.0/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>/Users/jleechan</string>
  </dict>
</dict>
</plist>
