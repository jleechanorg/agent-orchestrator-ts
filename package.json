{
  "name": "agent-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Orchestrate parallel AI coding agents across any runtime, any repo, any issue tracker",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @jleechanorg/ao-web dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --filter '!@jleechanorg/ao-web' test",
    "test:integration": "pnpm --filter @jleechanorg/ao-integration-tests test:integration",
    "clean": "pnpm -r clean",
    "prepare": "husky",
    "postinstall": "node scripts/rebuild-node-pty.js",
    "novel:backfill": "node scripts/novel/backfill-entries.mjs",
    "novel:daily": "node scripts/novel/generate-daily-entry.mjs --file novel/the-daily-lives-of-workers.md --days 1 --words 1000",
    "launchd:install": "bash scripts/setup-launchd.sh all"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jleechanorg/ao-plugin-agent-cursor": "workspace:^",
    "@jleechanorg/ao-plugin-agent-gemini": "workspace:^",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.2.3",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "glob": "^11.0.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript-eslint": "^8.55.0"
  }
}
