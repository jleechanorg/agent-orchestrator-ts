{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect-pr-close.sh",
            "timeout": 45000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/claim-verifier.sh",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/churn-guard.sh",
            "timeout": 60000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "AO_HOOK_EVENT_NAME='PreToolUse' bash .claude/metadata-updater.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "AO_HOOK_EVENT_NAME='PostToolUse' bash .claude/metadata-updater.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
