{
  "name": "@jleechanorg/ao-cli",
  "version": "0.1.3",
  "description": "CLI for agent-orchestrator \u2014 the `ao` command",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ao": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "scripts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ComposioHQ/agent-orchestrator.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ComposioHQ/agent-orchestrator",
  "bugs": {
    "url": "https://github.com/ComposioHQ/agent-orchestrator/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc && node --input-type=module --eval \"import{copyFileSync,mkdirSync,readdirSync,statSync}from'node:fs';import{join,dirname}from'node:path';import{fileURLToPath}from'node:url';const __dirname=dirname(fileURLToPath(import.meta.url));const src='src/templates',dst='dist/templates';mkdirSync(dst,{recursive:true});for(const f of readdirSync(src)){const s=join(src,f),d=join(dst,f);statSync(s).isDirectory()?(function copyDir(s,d){mkdirSync(d,{recursive:true});for(const e of readdirSync(s))copyDir(join(s,e),join(d,e))}(s,d)):(copyFileSync(s,d),process.stdout.write('Copied '+f+'\\n'));}\"",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@jleechanorg/ao-core": "workspace:*",
    "@jleechanorg/ao-plugin-agent-aider": "workspace:*",
    "@jleechanorg/ao-plugin-agent-claude-code": "workspace:*",
    "@jleechanorg/ao-plugin-agent-codex": "workspace:*",
    "@jleechanorg/ao-plugin-agent-cursor": "workspace:*",
    "@jleechanorg/ao-plugin-agent-gemini": "workspace:*",
    "@jleechanorg/ao-plugin-agent-opencode": "workspace:*",
    "@jleechanorg/ao-plugin-poller-github-pr": "workspace:*",
    "@jleechanorg/ao-plugin-notifier-composio": "workspace:*",
    "@jleechanorg/ao-plugin-notifier-desktop": "workspace:*",
    "@jleechanorg/ao-plugin-notifier-mcp-mail": "workspace:*",
    "@jleechanorg/ao-plugin-notifier-openclaw": "workspace:*",
    "@jleechanorg/ao-plugin-notifier-slack": "workspace:*",
    "@jleechanorg/ao-plugin-notifier-webhook": "workspace:*",
    "@jleechanorg/ao-plugin-runtime-antigravity": "workspace:*",
    "@jleechanorg/ao-plugin-runtime-process": "workspace:*",
    "@jleechanorg/ao-plugin-prose-polish": "workspace:*",
    "@jleechanorg/ao-plugin-runtime-tmux": "workspace:*",
    "@jleechanorg/ao-plugin-scm-github": "workspace:*",
    "@jleechanorg/ao-plugin-terminal-iterm2": "workspace:*",
    "@jleechanorg/ao-plugin-terminal-web": "workspace:*",
    "@jleechanorg/ao-plugin-tracker-github": "workspace:*",
    "@jleechanorg/ao-plugin-tracker-linear": "workspace:*",
    "@jleechanorg/ao-plugin-workspace-clone": "workspace:*",
    "@jleechanorg/ao-plugin-workspace-worktree": "workspace:*",
    "@jleechanorg/ao-web": "workspace:*",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "ora": "^8.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "@types/node": "^25.2.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
