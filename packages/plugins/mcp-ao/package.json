{
  "name": "@jleechanorg/ao-plugin-mcp-ao",
  "version": "0.1.0",
  "description": "MCP server plugin: AO operations (spawn, send, session list, etc.) wrapping the ao CLI commands",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "https://github.com/jleechanorg/agent-orchestrator.git",
    "directory": "packages/plugins/mcp-ao"
  },
  "homepage": "https://github.com/jleechanorg/agent-orchestrator",
  "bugs": {
    "url": "https://github.com/jleechanorg/agent-orchestrator/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@jleechanorg/ao-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
