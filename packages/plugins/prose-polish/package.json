{
  "name": "@jleechanorg/ao-plugin-prose-polish",
  "version": "0.1.0",
  "description": "Prose-polish runtime plugin: detects and suggests fixes for common fiction prose patterns",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "https://github.com/jleechanorg/agent-orchestrator.git",
    "directory": "packages/plugins/prose-polish"
  },
  "homepage": "https://github.com/jleechanorg/agent-orchestrator",
  "bugs": {
    "url": "https://github.com/jleechanorg/agent-orchestrator/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@jleechanorg/ao-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
