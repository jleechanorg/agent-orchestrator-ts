{
  "name": "@jleechanorg/ao-plugin-agent-base",
  "version": "0.1.0",
  "description": "Shared JSONL-based agent plugin factory for AO",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ComposioHQ/agent-orchestrator.git",
    "directory": "packages/plugins/agent-base"
  },
  "homepage": "https://github.com/ComposioHQ/agent-orchestrator",
  "bugs": {
    "url": "https://github.com/ComposioHQ/agent-orchestrator/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "pretest": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit --project tsconfig.test.json",
    "test:types": "tsc --noEmit --project tsconfig.test.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@jleechanorg/ao-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
