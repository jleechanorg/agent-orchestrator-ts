[0.3, "o", "\r\u001b[?1l===================================================================\r\r\n"]
[0.35, "o", "\r\n"]
[0.4, "o", "=== Step 1: Skeptic verdict on prior head 329894c9a ===\r\r\n"]
[0.45, "o", "(rejected with 3 blockers \u2014 see PR comments)\r\r\n"]
[0.5, "o", "\r\n"]
[0.55, "o", "=== Step 2: Bug #1 fix \u2014 local tmp_plist outside function ===\r\r\n"]
[0.6, "o", "    launchctl bootstrap \"gui/$(id -u)\" \"$TIER1_PLIST\" 2>/dev/null \\\r\r\n"]
[0.65, "o", "      && log \"bootstrap attempted for $TIER1_LABEL\" \\\r\r\n"]
[0.7, "o", "      || log \"bootstrap FAILED for $TIER1_LABEL (live plist present but rejected)\"\r\r\n"]
[0.75, "o", "  elif [ -f \"$TIER1_FROZEN_PLIST\" ]; then\r\r\n"]
[0.8, "o", "    # Frozen template contains @REPO_ROOT@, @HOME@, @PATH@ placeholders.\r\r\n"]
[0.85, "o", "    # Substitute them in place to ~/Library/LaunchAgents and bootstrap.\r\r\n"]
[0.9, "o", "    log \"frozen template found at $TIER1_FROZEN_PLIST \u2014 substituting placeholders\"\r\r\n"]
[0.95, "o", "    tmp_plist=$(mktemp \"/tmp/health-guardian-XXXXXX.plist\")\r\r\n"]
[1.0, "o", "    if sed -e \"s|@REPO_ROOT@|$REPO_ROOT|g\" \\\r\r\n"]
[1.05, "o", "           -e \"s|@HOME@|$HOME|g\" \\\r\r\n"]
[1.1, "o", "           -e \"s|@PATH@|${PATH:-/usr/local/bin:/usr/bin:/bin}|g\" \\\r\r\n"]
[1.15, "o", "           \"$TIER1_FROZEN_PLIST\" > \"$tmp_plist\" 2>/dev/null; then\r\r\n"]
[1.2, "o", "      mv -f \"$tmp_plist\" \"$TIER1_PLIST\"\r\r\n"]
[1.25, "o", "\r\n"]
[1.3, "o", "=== Step 3: Bug #2 fix \u2014 project-counting regex scoped to projects: ===\r\r\n"]
[1.35, "o", "  if ! grep -q \"scm:\" \"$cfg\"; then\r\r\n"]
[1.4, "o", "    fail \"staging config $cfg has NO 'scm:' field \u2014 skeptic will silently return 0 for all PRs (see fragility 2026-06-10)\"\r\r\n"]
[1.45, "o", "    return\r\r\n"]
[1.5, "o", "  fi\r\r\n"]
[1.55, "o", "  # Count projects defined under the top-level `projects:` map only. The\r\r\n"]
[1.6, "o", "  # project entries sit at exactly 2 spaces of indent (`  <name>:`). Nested\r\r\n"]
[1.65, "o", "  # sub-keys like `tracker:`, `agentConfig:`, `scm-github:`, etc. also\r\r\n"]
[1.7, "o", "  # match a 2-or-4-space YAML key pattern, so we anchor on the\r\r\n"]
[1.75, "o", "  # `projects:` section header and count keys until the next\r\r\n"]
[1.8, "o", "  # non-indented or shallower-indented key. This avoids false positives\r\r\n"]
[1.85, "o", "  # from `reactions:`, `notifier-routing:`, plugin configs, etc.\r\r\n"]
[1.9, "o", "  local project_count\r\r\n"]
[1.95, "o", "  project_count=$(awk '\r\r\n"]
[2.0, "o", "    BEGIN { in_projects=0; count=0 }\r\r\n"]
[2.05, "o", "    /^projects:[[:space:]]*$/ { in_projects=1; next }\r\r\n"]
[2.1, "o", "    in_projects && /^[^[:space:]]/ { in_projects=0 }\r\r\n"]
[2.15, "o", "    in_projects && /^  [a-zA-Z][a-zA-Z0-9_-]*:[[:space:]]*(#.*)?$/ { count++ }\r\r\n"]
[2.2, "o", "    END { print count+0 }\r\r\n"]
[2.25, "o", "  ' \"$cfg\")\r\r\n"]
[2.3, "o", "  local scm_count\r\r\n"]
[2.35, "o", "  scm_count=$(grep -cE \"^\\s+scm:\" \"$cfg\" 2>/dev/null || echo 0)\r\r\n"]
[2.4, "o", "  if [ \"$project_count\" -gt 0 ] && [ \"$scm_count\" -lt \"$project_count\" ]; then\r\r\n"]
[2.45, "o", "    warn \"staging config $cfg has $scm_count 'scm:' entries but $project_count project(s) \u2014 some projects will be silently skipped\"\r\r\n"]
[2.5, "o", "  else\r\r\n"]
[2.55, "o", "\r\n"]
[2.6, "o", "=== Step 4: TDD Red phase \u2014 current staging config has 0 scm: ===\r\r\n"]
[2.65, "o", "=== ao-doctor-v2 (2026-06-10 fragility audit) ===\r\r\n"]
