[22.05, "o", "Red phase (pre-bd-rgk0-fix \u2014 commit ac2207e1e^):\r\n"]
[22.55, "o", "  // Collect eligible PRs (non-draft, modified within last 24 hours) in a single pass before running\r\n"]
[23.05, "o", "  const eligiblePRs = openPRs.filter((pr) => {\r\n"]
[23.55, "o", "    if (pr.isDraft) return false;\r\n"]
