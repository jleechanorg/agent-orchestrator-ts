[24.55, "o", "      const updatedAtMs = Date.parse(pr.updatedAt);\r\n"]
[25.05, "o", "      if (Number.isFinite(updatedAtMs)) {\r\n"]
[25.55, "o", "        const ageMs = Date.now() - updatedAtMs;\r\n"]
[26.05, "o", "        const oneDayMs = 24 * 60 * 60 * 1000;\r\n"]
[26.55, "o", "        if (ageMs > oneDayMs) {\r\n"]
[27.05, "o", "          return false;\r\n"]
[27.55, "o", "        }\r\n"]
[28.05, "o", "      }\r\n"]
[28.55, "o", "    }\r\n"]
[29.05, "o", "    return true;\r\n"]
[29.55, "o", "  });\r\n"]
[30.05, "o", "\r\n"]
